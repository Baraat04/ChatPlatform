// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BotPlatform {
  TELEGRAM
  WHATSAPP
}

model User {
  id                Int      @id @default(autoincrement())
  name              String
  
  // --- Added Fields ---
  email             String?  @unique
  password          String?
  messagesRemaining Int      @default(0)
  totalMessagesUsed Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relation to Bots (One-to-Many)
  bots                 Bot[]
  usage                AIUsage[]
  messageTransactions  MessageTransaction[]
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   @db.Text
  expiresAt DateTime
}

model Bot {
  id            Int      @id @default(autoincrement())
  slug          String   @unique         // Slugs should generally be unique for routing/webhooks
  // Using @db.Text is recommended for prompts since they can exceed standard varchar limits
  system_prompt String?  @db.Text
  data_prompt   String?  @db.Text
  
  // --- Added Fields ---
  platform      BotPlatform              // Specifies if it's Telegram or WhatsApp
  apiToken      String?                  // Needed to authenticate the bot with Telegram/WhatsApp
  isActive      Boolean  @default(true)  // Allows users to turn bots on/off without deleting them
  pausedChats   String[] @default([])    // Array of chat IDs where AI auto-reply is disabled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign Key and Relation (Matches your diagram)
  user_id       Int
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  whatsappSessions BaileysSession[]
  messages         Message[]
  usage            AIUsage[]

  // Adding an index on the foreign key improves query performance
  @@index([user_id])
}

model BaileysSession {
  id        String   @id @default(uuid())
  botId     Int
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  category  String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, category, key])
}

model Message {
  id        Int      @id @default(autoincrement())
  botId     Int
  bot       Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  sender    String   // 'user' or 'bot'
  text      String   @db.Text
  chatId    String   // phone number or telegram chat id
  createdAt DateTime @default(now())

  @@index([botId, chatId])
}

model Contact {
  id        Int      @id @default(autoincrement())
  botId     Int
  chatId    String
  name      String
  realJid   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([botId, chatId])
}

model AIUsage {
  id             Int      @id @default(autoincrement())

  userId         Int
  botId          Int

  provider       String
  model          String

  inputTokens    Int
  outputTokens   Int
  totalTokens    Int

  messagesUsed   Int

  providerCost   Float
  estimatedRevenue Float

  createdAt      DateTime @default(now())

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot            Bot  @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([botId])
  @@index([createdAt])
}

model MessageTransaction {
  id               Int      @id @default(autoincrement())

  userId           Int
  amount           Int      // positive = purchase, negative = usage

  type             String   // purchase, usage, bonus, refund

  description      String?

  model            String?

  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?

  messagesUsed     Int?

  providerCost     Float?
  estimatedRevenue Float?

  createdAt        DateTime @default(now())

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
